{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with role-based access",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["applicant", "admin"] },
        "title": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "projects": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "link": { "type": "string" }
            }
          } 
        },
        "badges": { "type": "array", "items": { "type": "string" } },
        "isBlocked": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "MasterStudent": {
      "title": "Master Student",
      "description": "Student in the master list",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "studentId": { "type": "string" },
        "department": { "type": "string" }
      },
      "required": ["name", "email"]
    },
    "Session": {
      "title": "Session",
      "description": "An attendance session",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "date"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Attendance record for a student in a session",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "studentEmail": { "type": "string" },
        "studentName": { "type": "string" },
        "status": { "type": "string", "enum": ["present", "absent"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["sessionId", "studentEmail", "status"]
    },
    "BlockedEmail": {
      "title": "Blocked Email",
      "description": "Email addresses blocked from registration",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "blockedAt": { "type": "string", "format": "date-time" },
        "reason": { "type": "string" }
      },
      "required": ["email", "blockedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/masterStudents/{studentId}": { "schema": "MasterStudent", "description": "Master list of students" },
    "/sessions/{sessionId}": { "schema": "Session", "description": "Attendance sessions" },
    "/attendance/{attendanceId}": { "schema": "Attendance", "description": "Attendance records" },
    "/blockedEmails/{email}": { "schema": "BlockedEmail", "description": "Blocked email addresses" }
  }
}
