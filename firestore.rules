rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, name, email, role, createdAt
    //
    // Collection: masterStudents
    // Fields: name, email, studentId, department
    //
    // Collection: sessions
    // Fields: name, date, description, createdAt
    //
    // Collection: attendance
    // Fields: sessionId, studentEmail, studentName, status, timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "mrmostafash187@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'name', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.role in ['applicant', 'admin'] &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidMasterStudent(data) {
      return hasRequiredFields(['name', 'email']) &&
             data.name is string && data.name.size() > 0 &&
             data.email is string && data.email.size() > 0;
    }

    function isValidSession(data) {
      return hasRequiredFields(['name', 'date']) &&
             data.name is string && data.name.size() > 0;
    }

    function isValidAttendance(data) {
      return hasRequiredFields(['sessionId', 'studentEmail', 'status']) &&
             data.status in ['present', 'absent'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'applicant' || isAdmin());
      allow update: if isAuthenticated() && (
        (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role) || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /masterStudents/{studentId} {
      allow read, write: if isAdmin();
    }

    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.token.email == resource.data.studentEmail);
      allow write: if isAdmin();
    }
  }
}
